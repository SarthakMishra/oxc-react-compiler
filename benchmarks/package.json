{
  "name": "oxc-react-compiler-benchmarks",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "node bench.mjs",
    "bench:update-snapshots": "node bench.mjs --update-snapshots",
    "bench:check-snapshots": "node bench.mjs --check-snapshots",
    "extract-fixtures": "bash scripts/extract-fixtures.sh",
    "babel:update-snapshots": "node scripts/babel-compile.mjs --update-snapshots",
    "babel:diff": "node scripts/babel-compile.mjs --diff",
    "babel:diff-json": "node scripts/babel-compile.mjs --diff --format json",
    "correctness": "node scripts/analyze-correctness.mjs --all",
    "render:compare": "node scripts/render-compare.mjs",
    "render:compare-json": "node scripts/render-compare.mjs --format json",
    "render:compare-verbose": "node scripts/render-compare.mjs --verbose",
    "compare": "node scripts/bench-compare.mjs",
    "compare:json": "node scripts/bench-compare.mjs --format json",
    "compare:quick": "node scripts/bench-compare.mjs --iterations 20 --warmup 5",
    "runtime": "node scripts/runtime-bench.mjs",
    "runtime:json": "node scripts/runtime-bench.mjs --format json",
    "e2e": "node e2e/e2e-bench.mjs",
    "e2e:json": "node e2e/e2e-bench.mjs --format json",
    "e2e:quick": "node e2e/e2e-bench.mjs --iterations 1"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.27.3",
    "oxc-react-compiler": "file:../napi/react-compiler",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
